# ──────────────────────────────────────────────────────
# Audio Analysis System – Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── Gemini API (required) ──────────────────────────────
# Get your free API key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── FFmpeg Paths (optional – auto-detected if in PATH) ─
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── API Server ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_in_production

# ── Audio Recording Defaults ──────────────────────────
SAMPLE_RATE=44100
CHANNELS=1
RECORD_CHUNK_SECONDS=30

# ── Analysis Thresholds ───────────────────────────────
# Silence: audio below this dB is considered silent
SILENCE_THRESHOLD_DB=-30
# Minimum silence segment length (seconds)
SILENCE_MIN_DURATION=2.0
# Volume below this is flagged as "too quiet"
LOW_VOLUME_THRESHOLD_DB=-40
# Clipping: peak above this fraction of max is flagged
CLIPPING_PEAK_FRACTION=0.99
# Silence ratio above this triggers a warning (0.0–1.0)
HIGH_SILENCE_RATIO_THRESHOLD=0.2
# Noise floor above this dB is flagged as noisy
NOISE_FLOOR_THRESHOLD_DB=-50

# ── Storage ───────────────────────────────────────────
OUTPUT_DIR=./output
TEMP_DIR=./temp
